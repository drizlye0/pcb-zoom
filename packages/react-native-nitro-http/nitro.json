{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrohttp"
  ],
  "ios": {
    "iosModuleName": "NitroHttp"
  },
  "android": {
    "androidNamespace": [
      "nitrohttp"
    ],
    "androidCxxLibName": "NitroHttp"
  },
  "autolinking": {
    "HttpServer": {
      "android": {
        "language": "c++",
        "implementationClassName": "HybridHttpServer"
      }
    },
    "ServerManager": {
      "android": {
        "language": "c++",
        "implementationClassName": "HybridServerManager"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
