{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrohttp"
  ],
  "ios": {
    "iosModuleName": "NitroHttp"
  },
  "android": {
    "androidNamespace": [
      "nitrohttp"
    ],
    "androidCxxLibName": "NitroHttp"
  },
  "autolinking": {
    "CallbackManager": {
      "android": {
        "language": "c++",
        "implementationClassName": "HCallbackManager"
      }
    },
    "SignalingServer": {
     "android": {
       "language": "kotlin",
       "implementationClassName": "HSignalingServer"
     }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
